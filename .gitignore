# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.db
!prisma/*.db  # Keep prisma directory structure but ignore db files in git
# Test database (generated during test runs)
test.db
test.db-journal

/src/generated/prisma

# Uploaded ad images (user uploads)
# Track only seed images in root, ignore advertiser subdirectories
/public/uploads/ads/*/
!/public/uploads/ads/*.jpg
!/public/uploads/ads/*.jpeg
!/public/uploads/ads/*.png
!/public/uploads/ads/*.gif
